# ─────────────────────────────────────────────────────────────────────────────
# Oracle (provider) agent — environment configuration
#
# Copy this file to `.env` and fill in your own values. NEVER commit a populated
# `.env`. `actp init` adds `.env` and `.env.*` to .gitignore; this `.env.example`
# documents the schema and is the only env file that should be committed.
#
# Loading: agent.js calls `dotenv.config()` then `dotenv.config({ path: '.env.local' })`.
# dotenv does NOT overwrite already-set vars, so process-level env wins over `.env`,
# which wins over `.env.local`. By convention the keyed RPC URL lives in `.env.local`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Wallet selection (pick ONE of the two patterns below) ────────────────────
# The SDK resolves the signing wallet from these vars (see SDK wallet/keystore).
# Resolution order: ACTP_PRIVATE_KEY (policy-gated) → ACTP_KEYSTORE_BASE64 +
# ACTP_KEY_PASSWORD → on-disk .actp/keystore.json + ACTP_KEY_PASSWORD.
#
# Pattern A — encrypted keystore + password (recommended for CI / deploy):
# Base64 of your `.actp/keystore.json` (the encrypted keystore blob, not the key).
ACTP_KEYSTORE_BASE64=base64-of-your-actp-keystore-json
# Password that decrypts the keystore above. Required whenever a keystore is used.
ACTP_KEY_PASSWORD=your-keystore-password
#
# Pattern B — raw private key (testnet ONLY; mainnet/unknown network refuses this
# path and fails closed). Leave Pattern A blank if you use this. Never use on mainnet.
ACTP_PRIVATE_KEY=0xyour-testnet-private-key

# ── Network ──────────────────────────────────────────────────────────────────
# Network tier the SDK uses for the fail-closed wallet-policy check (mock | testnet
# | mainnet). agent.js pins the Agent to 'testnet', but the keystore policy still
# reads ACTP_NETWORK as its fallback; set it to keep the policy unambiguous.
ACTP_NETWORK=testnet

# Base Sepolia JSON-RPC endpoint. STRONGLY recommended: the free public node caps
# eth_getLogs at 2000 blocks and drops persistent filters, which silently breaks
# the SDK's long-running event poller (it would miss escrow events and never pick
# up jobs). Use a keyed single-endpoint provider (Alchemy / Infura / QuickNode) so
# the poller has a stable, high-limit filter source. Conventionally set in `.env.local`.
# Paste the full keyed URL your provider gives you (it embeds your API key — keep secret).
BASE_SEPOLIA_RPC=https://<your-rpc-provider-host>/<your-api-key>

# Catch-up sweep window, in blocks, for the event poller. On restart the SDK queries
# logs from (currentBlock - ACTP_SWEEP_BLOCK_WINDOW) so jobs escrowed while Oracle was
# down are still picked up. Read by the SDK (config > env > default 7200 ≈ 4h on Base
# L2). Tune to your container restart cadence; larger = wider catch-up, more RPC load.
ACTP_SWEEP_BLOCK_WINDOW=7200

# ── Email transport (AgentMail) ──────────────────────────────────────────────
# AgentMail API key — authenticates this process to AgentMail. Used by negotiate.js
# and request-inbox.js to poll the inbox and send the brief. Generate one in the
# AgentMail dashboard (https://agentmail.to) and keep it secret.
#
# SECRET — never paste a real key into this committed example. In your local `.env`
# (or `.env.local`), add a single line that assigns your key to the variable named:
#     AGENTMAIL_API_KEY      (the code reads it as process.env.AGENTMAIL_API_KEY)
# Format:  <THAT_VARIABLE_NAME><equals-sign><your-agentmail-api-key>
# Intentionally left unset here so no secret-shaped assignment is committed.

# Oracle's own AgentMail inbox address. The buyer's topic request ([ACTP-REQUEST])
# and price handshakes ([ACTP-NEGOTIATE]) arrive HERE, and the finished brief is
# sent FROM here. Read by negotiate.js and request-inbox.js as ORACLE_INBOX.
ORACLE_INBOX=your-provider-inbox@agentmail.to

# ── Display-only banner ──────────────────────────────────────────────────────
# Oracle's own on-chain Smart Wallet address (where escrow settles). Printed in the
# startup banner ONLY — the SDK resolves the real signing wallet from the keystore /
# private key above, so this is purely cosmetic and safe to leave unset.
ORACLE_WALLET=0xYourProviderAgentWalletAddress

# ── Brain (Claude) ───────────────────────────────────────────────────────────
# Path or command name for the Claude CLI binary the brain shells out to for
# research. Read by brain.js; defaults to 'claude' (must be on PATH) if unset.
CLAUDE_BIN=claude

# Claude model the brain uses to write the brief. Read by brain.js; defaults to
# 'claude-sonnet-4-6' if unset. Override for a stronger or cheaper model.
ORACLE_BRAIN_MODEL=claude-sonnet-4-6
