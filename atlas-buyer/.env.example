# ─────────────────────────────────────────────────────────────────────────────
# Atlas (buyer) agent — environment configuration
#
# Copy this file to `.env` and fill in YOUR OWN values:  cp .env.example .env
# NEVER commit your real `.env`. `.gitignore` already ignores `.env` and `.env.*`
# (everything except this committed `.env.example`). The values below are
# PLACEHOLDERS only — no real key, inbox, or wallet appears in this file.
#
# Which process reads what:
#   • Atlas's own JS (listener/brain/negotiate/escrow/commerce/state) reads the
#     vars marked "(read by Atlas)".
#   • The on-chain wallet vars (ACTP_*) are read by the `actp` CLI that Atlas
#     spawns. Atlas forwards the full environment to it (env: { ...process.env }),
#     so simply having them in `.env` is enough — they never appear in code.
# ─────────────────────────────────────────────────────────────────────────────


# ═══ WALLET / SIGNING (read by the spawned `actp` CLI) ═══════════════════════
# Atlas transacts on-chain by shelling out to the `actp` CLI with cwd=this dir,
# so the CLI uses the keystore onboarded HERE. Pick ONE of the two patterns:
#
# ── Pattern A — encrypted keystore + password (recommended; works on mainnet) ──
# Base64 of your `.actp/keystore.json`. Produce both lines with `actp deploy:env`.
# Get/create a keystore by onboarding this agent: `npx actp init` in this dir.
ACTP_KEYSTORE_BASE64=base64-of-your-actp-keystore-json
# Password that decrypts the keystore above. Keep it secret.
ACTP_KEY_PASSWORD=your-keystore-password
#
# ── Pattern B — raw private key (TESTNET ONLY; mainnet refuses this path) ──
# Uncomment for quick testnet runs instead of Pattern A. Never use on mainnet.
# ACTP_PRIVATE_KEY=0xyour_testnet_private_key_hex


# ═══ NETWORK ═════════════════════════════════════════════════════════════════
# Chain the `actp` CLI targets: mock | testnet | mainnet.
# "testnet" = Base Sepolia (default for this template). Use "mainnet" for real USDC.
ACTP_NETWORK=testnet


# ═══ ON-CHAIN ADDRESSES (read by Atlas) ══════════════════════════════════════
# REQUIRED. The provider (Oracle) agent's on-chain wallet. Escrow opens in its
# favour and releases here on settlement. Use the address of who you buy from.
ORACLE_ADDR=0xYourProviderAgentWalletAddress
#
# REQUIRED. Atlas's OWN on-chain requester address (the Smart Wallet that holds
# escrowed funds). Stamped on receipts as `requesterAddress` and used to build the
# block-explorer link emailed back to the principal. May differ from the signing
# EOA in the 3-tier wallet model. Set it to your funded buyer/smart-wallet address.
BUYER_WALLET=0xYourBuyerSmartWalletAddress


# ═══ AGENTMAIL — EMAIL TRANSPORT (read by Atlas) ═════════════════════════════
# REQUIRED. Atlas's own AgentMail inbox: the principal emails requests here, and
# the delivered brief lands back here. Provision one at https://agentmail.to
BUYER_INBOX=your-buyer-inbox@agentmail.to
#
# REQUIRED. The provider (Oracle) agent's AgentMail inbox — where Atlas sends the
# work request (the "topic") and negotiation offers TO. No safe default; fails loud.
ORACLE_INBOX_ADDR=your-provider-inbox@agentmail.to
#
# REQUIRED. AgentMail API key — authenticates this process to the AgentMail
# service for send/list/get. Generate it in the AgentMail dashboard. Keep secret.
# Read by Atlas via process.env.AGENTMAIL_API_KEY (see commerce.js / listener.js).
# Leave EMPTY here. Set the real value only in your local (gitignored) .env, e.g.
#   AGENTMAIL_API_KEY=am_live_xxxxxxxxxxxxxxxxxxxxxxxx   <-- in .env, never here.
AGENTMAIL_API_KEY=


# ═══ BRAIN — CLAUDE CLI (read by Atlas) ══════════════════════════════════════
# Optional. Which Claude CLI binary to invoke. Defaults to `claude` on PATH, so
# nothing machine-specific is baked in. Set an absolute path only if your launcher
# can't put `claude` on PATH (e.g. CLAUDE_BIN=/opt/anthropic/bin/claude).
CLAUDE_BIN=claude
#
# Optional. The Claude model the CLI uses. Tune cost/latency/quality without code
# changes. Defaults to "claude-sonnet-4-6".
BUYER_BRAIN_MODEL=claude-sonnet-4-6
#
# Optional. Max ms a single `claude -p` brain call may run before it is killed.
# Real replies take ~80-120s, so the default (300000 = 5 min) is intentionally
# generous. Lower only if your model/latency profile is faster.
BRAIN_TIMEOUT_MS=300000


# ═══ SERVICE & RPC (read by Atlas) ═══════════════════════════════════════════
# Optional. The service name Atlas buys; its keccak256 hash routes the escrow to
# the provider's matching handler. Must match the provider's service. Default "intel-brief".
SERVICE_NAME=intel-brief
#
# Optional. Base Sepolia (testnet) JSON-RPC endpoint, forwarded to the `actp` CLI.
# Defaults to a free public node so the template runs out-of-the-box. Supply your
# own (e.g. Alchemy/Infura) for production-grade rate limits and reliability.
BASE_SEPOLIA_RPC=https://base-sepolia-rpc.publicnode.com
#
# Optional. Base mainnet JSON-RPC endpoint (only needed when ACTP_NETWORK=mainnet;
# read by the `actp` CLI). Supply your own provider URL for mainnet traffic.
# BASE_MAINNET_RPC=https://mainnet.base.org


# ═══ LISTENER / BUDGET TUNING (read by Atlas) ════════════════════════════════
# Optional. Inbox poll interval in ms. How often listener.js checks for new mail.
# Default 8000 (8s).
POLL_MS=8000
#
# Optional. Max number of commissions Atlas runs in flight at once. Default 4.
MAX_CONCURRENT=4
#
# Optional. Hard ceiling (USDC) Atlas will ever escrow for one request. Safety cap
# that defuses a prompt-injected attempt to inflate the budget. Default 25.
MAX_BUDGET=25
#
# Optional. Price floor (USDC) the provider won't take a job below; used by the
# negotiator to bound counter-offers. Default 8.
ORACLE_FLOOR=8


# ═══ DURABLE STATE (read by Atlas) ═══════════════════════════════════════════
# Optional. Path to Atlas's durable state file (processed-message dedupe + held
# escrows for crash-safe reconciliation). Defaults to `.atlas-state.json` next to
# the code. Override to run multiple agents from one checkout, or to put state on
# a mounted volume so it survives container redeploys (recommended in production).
ATLAS_STATE_PATH=.atlas-state.json
